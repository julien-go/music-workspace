# Local development — read by docker-compose for the Postgres container.
# Copy to .env and adjust if needed. Never put real production values here.

# Database name created by the Postgres container
POSTGRES_DB=music_workspace
# Local Postgres superuser (docker-compose default)
POSTGRES_USER=postgres
# Local-only password — matches the docker-compose fallback
POSTGRES_PASSWORD=postgres
# Host port mapped to the container's 5432
POSTGRES_PORT=5433

# Backend runtime variables (JWT, Cloudinary, frontend URL...) are documented
# in backend/.env.example. For local runs they live in
# backend/src/main/resources/application-dev.yml (see application-dev.yml.example).
