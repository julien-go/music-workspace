# Backend runtime environment — these are the variables the API needs in
# production (set them as Railway service variables). Local development does
# not use a .env file: copy application-dev.yml.example to application-dev.yml
# instead. Never commit real values.

# Spring profile to activate: dev (default) or prod
SPRING_PROFILES_ACTIVE=prod

# PostgreSQL JDBC URL (Railway: from the Postgres service)
DB_URL=jdbc:postgresql://host:5432/database
# Database user
DB_USERNAME=changeme
# Database password
DB_PASSWORD=changeme

# JWT signing key, base64-encoded, at least 256 bits — generate with: openssl rand -base64 64
JWT_SECRET=changeme-base64-encoded-secret

# JWT lifetime in milliseconds — optional, defaults to 7 days
JWT_EXPIRATION_MS=604800000

# Cloudinary credentials, copied from the Cloudinary dashboard
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Public URL of the deployed frontend (no trailing slash) — required in prod,
# startup fails fast without it; feeds CORS and the origin-based CSRF guard
FRONTEND_URL=https://your-site.netlify.app

# Trusted proxy hops appending to X-Forwarded-For (rate limiting reads the
# client IP from the right of that header) — optional, prod defaults to 2
# (Netlify proxy + Railway edge)
TRUSTED_PROXY_HOPS=2
